<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hotel Booking System</title>

    <!-- DaisyUI + Tailwind CSS -->
    <link href="https://cdn.jsdelivr.net/npm/daisyui@3.7.3/dist/full.css" rel="stylesheet" type="text/css" />
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Custom Styles -->
    <style>
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .hero {
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/images/hero-bg.jpg');
            background-size: cover;
            background-position: center;
            color: white;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <div class="navbar bg-base-100 shadow-lg">
        <div class="navbar-start">
            <div class="dropdown">
                <label tabindex="0" class="btn btn-ghost lg:hidden">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" /></svg>
                </label>
                <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
                    <li><a href="/">Home</a></li>
                    <li><a href="/Room">Rooms</a></li>
                    <li><a href="/Room/Availability">Check Availability</a></li>
                    <li><a href="/Booking/MyBookings">My Bookings</a></li>
                </ul>
            </div>
            <a href="/" class="btn btn-ghost normal-case text-xl">
                <i class="fas fa-hotel text-primary mr-2"></i>
                <span class="hidden md:inline">Hotel Booking</span>
            </a>
        </div>
        <div class="navbar-center hidden lg:flex">
            <ul class="menu menu-horizontal px-1">
                <li><a href="/">Home</a></li>
                <li><a href="/Room">Rooms</a></li>
                <li><a href="/Room/Availability">Check Availability</a></li>
                <li><a href="/Booking/MyBookings">My Bookings</a></li>
            </ul>
        </div>
        <div class="navbar-end">
            <a href="/Booking/MyBookings" class="btn btn-outline btn-primary mr-2">
                <i class="fas fa-calendar-check mr-2"></i>
                <span class="hidden md:inline">My Bookings</span>
            </a>
            <a href="/Room/Availability" class="btn btn-primary">
                <i class="fas fa-bed mr-2"></i>
                <span class="hidden md:inline">Book Now</span>
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <main>
        <!-- Display messages -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="toast toast-top toast-end">
                <div class="alert alert-success">
                    <div>
                        <i class="fas fa-check-circle mr-2"></i>
                        <span>@TempData["SuccessMessage"]</span>
                    </div>
                </div>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="toast toast-top toast-end">
                <div class="alert alert-error">
                    <div>
                        <i class="fas fa-exclamation-circle mr-2"></i>
                        <span>@TempData["ErrorMessage"]</span>
                    </div>
                </div>
            </div>
        }

        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer footer-center p-10 bg-base-200 text-base-content rounded">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
                <i class="fas fa-hotel text-3xl text-primary mb-4"></i>
                <p class="font-bold text-lg">Hotel Booking System</p>
                <p>Providing luxury stays since 2024</p>
            </div>
            <div>
                <p class="font-bold text-lg mb-4">Quick Links</p>
                <div class="grid grid-cols-2 gap-2">
                    <a href="/" class="link link-hover">Home</a>
                    <a href="/Room" class="link link-hover">Rooms</a>
                    <a href="/Room/Availability" class="link link-hover">Check Availability</a>
                    <a href="/Booking/MyBookings" class="link link-hover">My Bookings</a>
                </div>
            </div>
            <div>
                <p class="font-bold text-lg mb-4">Contact Us</p>
                <div class="space-y-2">
                    <div class="flex items-center">
                        <i class="fas fa-phone mr-2"></i>
                        <span>+1 (555) 123-4567</span>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-envelope mr-2"></i>
                        <span>info@hotelbooking.com</span>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-map-marker-alt mr-2"></i>
                        <span>123 Luxury Street, City, Country</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="divider"></div>
        <div>
            <p>Copyright © @DateTime.Now.Year - All rights reserved</p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Auto-hide toast messages after 5 seconds
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(function() {
                const toasts = document.querySelectorAll('.toast');
                toasts.forEach(toast => {
                    toast.style.opacity = '0';
                    setTimeout(() => toast.remove(), 300);
                });
            }, 5000);
        });
    </script>
</body>
</html>